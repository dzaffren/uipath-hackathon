{
  "document": {
    "dsl": "1.0.0",
    "name": "DecisionGate",
    "version": "0.0.1",
    "namespace": "default",
    "metadata": {
      "variables": {
        "schema": {
          "format": "json",
          "document": {
            "type": "object",
            "properties": {
              "validated_citations": { "type": "array",   "default": [] },
              "has_unverified":      { "type": "boolean", "default": false },
              "assessment_id":       { "type": "string",  "default": "" }
            },
            "title": "Variables"
          }
        }
      }
    }
  },
  "input": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "alert_id":        { "type": "string" },
          "evidence_bundle": { "type": "array"  },
          "agent_output":    { "type": "object" }
        },
        "required": ["alert_id", "evidence_bundle", "agent_output"],
        "title": "Inputs"
      }
    }
  },
  "output": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "validated_citations": { "type": "array"   },
          "has_unverified":      { "type": "boolean" },
          "final_risk_tier":     { "type": "string"  },
          "route":               { "type": "string"  }
        },
        "title": "Outputs"
      }
    }
  },
  "do": [
    {
      "Sequence_1": {
        "do": [
          {
            "WorkflowStart": {
              "set": "${Object.entries($workflow.definition?.document?.metadata?.variables?.schema?.document?.properties || {}).reduce((acc, [name, def]) => ({ ...acc, [name]: def?.default }), {}) }",
              "output": { "as": "${$input}" },
              "export": { "as": "{ ...$context, variables: { ...$context.variables, ...$output } }" },
              "metadata": { "activityType": "Assign", "displayName": "Workflow start", "fullName": "Assign", "isTransparent": true }
            }
          },
          {
            "Javascript_ValidateAndCheck": {
              "run": {
                "script": {
                  "code": "const alertId = $workflow.input.alert_id;\nconst evidenceBundle = $workflow.input.evidence_bundle;\nconst agentOutput = $workflow.input.agent_output;\nif (!alertId) throw new Error('VALIDATION_ERROR: alert_id is required');\nif (!Array.isArray(evidenceBundle)) throw new Error('VALIDATION_ERROR: evidence_bundle must be an array');\nif (!agentOutput || !Array.isArray(agentOutput.citations)) throw new Error('VALIDATION_ERROR: agent_output.citations must be an array');\nconst bundleIds = new Set(evidenceBundle.map(function(e) { return e.evidence_id; }));\nconst RISK_TIER_MAP = { 'low': 0, 'medium': 1, 'high': 2 };\nconst RECOMMENDATION_MAP = { 'escalate': 0, 'close': 1 };\nconst validatedCitations = agentOutput.citations.map(function(cid) {\n  const isVerified = bundleIds.has(cid);\n  return { evidence_id: cid, outcome: isVerified ? 'verified' : 'unverified_flagged', check_outcome_number_id: isVerified ? 0 : 1 };\n});\nconst hasUnverified = validatedCitations.some(function(c) { return c.outcome === 'unverified_flagged'; });\nconst riskTierLower = (agentOutput.risk_tier || 'medium').toLowerCase();\nconst recommendationLower = (agentOutput.recommendation || 'close').toLowerCase();\nconst proposedRiskTierNumberId = RISK_TIER_MAP[riskTierLower] !== undefined ? RISK_TIER_MAP[riskTierLower] : 1;\nconst recommendationNumberId = RECOMMENDATION_MAP[recommendationLower] !== undefined ? RECOMMENDATION_MAP[recommendationLower] : 0;\nreturn { validated_citations: validatedCitations, has_unverified: hasUnverified, proposed_risk_tier_number_id: proposedRiskTierNumberId, recommendation_number_id: recommendationNumberId, confidence: agentOutput.confidence || 0, rationale: agentOutput.rationale || '', cited_evidence_ids_json: JSON.stringify(agentOutput.citations), final_risk_tier: agentOutput.risk_tier || 'medium', route: 'medium_signoff' };",
                  "language": "javascript",
                  "arguments": "${{ \"$context\": $context, \"$workflow\": $workflow, \"$input\": $input }}"
                }
              },
              "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Javascript_ValidateAndCheck\": $output } }" },
              "metadata": { "activityType": "JsInvoke", "displayName": "Validate citations against bundle", "fullName": "JsInvoke" }
            }
          },
          {
            "Assign_ValidatedCitations": {
              "set": { "validated_citations": "${$context.outputs.Javascript_ValidateAndCheck.validated_citations}" },
              "export": { "as": "{ ...$context, variables: { ...$context.variables, ...$output } }" },
              "metadata": { "activityType": "Assign", "displayName": "Store validated citations", "fullName": "Assign", "isTransparent": false }
            }
          },
          {
            "Assign_HasUnverified": {
              "set": { "has_unverified": "${$context.outputs.Javascript_ValidateAndCheck.has_unverified}" },
              "export": { "as": "{ ...$context, variables: { ...$context.variables, ...$output } }" },
              "metadata": { "activityType": "Assign", "displayName": "Store has_unverified flag", "fullName": "Assign", "isTransparent": false }
            }
          },
          {
            "CreateEntityRecordCurated_AgentAssessment": {
              "call": "UiPath.IntSvc",
              "with": {
                "Connector": "uipath-uipath-dataservice",
                "ConnectionId": "4cd9774f-3809-4ed7-9fe6-23835f2434ee",
                "ConnectionResourceId": "4cd9774f-3809-4ed7-9fe6-23835f2434ee",
                "Method": "POST",
                "Endpoint": "/v2/{entityName}/CreateEntityRecord",
                "QueryParameters": {},
                "PathParameters": { "entityName": "AgentAssessment" },
                "BodyParameters": {
                  "AlertLink": "${$workflow.input.alert_id}",
                  "ProposedRiskTier": "${$context.outputs.Javascript_ValidateAndCheck.proposed_risk_tier_number_id}",
                  "Confidence": "${$context.outputs.Javascript_ValidateAndCheck.confidence}",
                  "Recommendation": "${$context.outputs.Javascript_ValidateAndCheck.recommendation_number_id}",
                  "Rationale": "${$context.outputs.Javascript_ValidateAndCheck.rationale}",
                  "CitedEvidenceIds": "${$context.outputs.Javascript_ValidateAndCheck.cited_evidence_ids_json}",
                  "ModelName": "anthropic.claude-sonnet-4-6"
                }
              },
              "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"CreateEntityRecordCurated_AgentAssessment\": $output } }" },
              "metadata": {
                "fullName": "Connector",
                "activityType": "Connector",
                "displayName": "Create AgentAssessment record",
                "uiPathActivityTypeId": "dfd2bc7a-ca4b-3316-8a1f-57c9e106dfbf",
                "assemblyQualifiedName": "Connector",
                "configuration": "{\"essentialConfiguration\":{\"connectorVersion\":\"\",\"executionType\":null,\"customFieldsRequestDetails\":null,\"instanceParameters\":{\"version\":\"1.0.0\",\"connectorKey\":\"uipath-uipath-dataservice\",\"activityType\":\"Curated\",\"objectName\":\"CreateEntityRecordCurated\",\"httpMethod\":\"POST\",\"operation\":null,\"eventOperation\":null,\"eventMode\":null,\"connectorObjects\":null,\"previewEndpoint\":null},\"objectName\":\"CreateEntityRecordCurated\",\"operation\":null,\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/v2/{entityName}/CreateEntityRecord\",\"unifiedTypesCompatible\":true,\"savedJitInputFieldId\":\"in_CreateEntityRecordCurated\"}}"
              }
            }
          },
          {
            "Javascript_ExtractAssessmentId": {
              "run": {
                "script": {
                  "code": "const cr = $context.outputs.CreateEntityRecordCurated_AgentAssessment;\nconst id = (cr && cr.content && cr.content.Id !== undefined) ? cr.content.Id : (cr && cr.content && cr.content.id !== undefined) ? cr.content.id : '';\nreturn id;",
                  "language": "javascript",
                  "arguments": "${{ \"$context\": $context, \"$workflow\": $workflow, \"$input\": $input }}"
                }
              },
              "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Javascript_ExtractAssessmentId\": $output } }" },
              "metadata": { "activityType": "JsInvoke", "displayName": "Extract AgentAssessment UUID", "fullName": "JsInvoke" }
            }
          },
          {
            "Assign_AssessmentId": {
              "set": { "assessment_id": "${$context.outputs.Javascript_ExtractAssessmentId}" },
              "export": { "as": "{ ...$context, variables: { ...$context.variables, ...$output } }" },
              "metadata": { "activityType": "Assign", "displayName": "Store assessment_id", "fullName": "Assign", "isTransparent": false }
            }
          },
          {
            "For_Each_2": {
              "for": {
                "each": "citationItem",
                "in": "${$context.variables.validated_citations}",
                "at": "citationItemIndex"
              },
              "do": [
                {
                  "For_Each_2#Body": {
                    "do": [
                      {
                        "Try_Catch_2": {
                          "try": [
                            {
                              "CreateEntityRecordCurated_CitationCheck": {
                                "call": "UiPath.IntSvc",
                                "with": {
                                  "Connector": "uipath-uipath-dataservice",
                                  "ConnectionId": "4cd9774f-3809-4ed7-9fe6-23835f2434ee",
                                  "ConnectionResourceId": "4cd9774f-3809-4ed7-9fe6-23835f2434ee",
                                  "Method": "POST",
                                  "Endpoint": "/v2/{entityName}/CreateEntityRecord",
                                  "QueryParameters": {},
                                  "PathParameters": { "entityName": "CitationCheck" },
                                  "BodyParameters": {
                                    "AlertLink": "${$workflow.input.alert_id}",
                                    "CitedEvidenceId": "${$citationItem.evidence_id}",
                                    "CheckOutcome": "${$citationItem.check_outcome_number_id}"
                                  }
                                },
                                "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"CreateEntityRecordCurated_CitationCheck\": $output } }" },
                                "metadata": {
                                  "fullName": "Connector",
                                  "activityType": "Connector",
                                  "displayName": "Create CitationCheck record",
                                  "uiPathActivityTypeId": "dfd2bc7a-ca4b-3316-8a1f-57c9e106dfbf",
                                  "assemblyQualifiedName": "Connector",
                                  "configuration": "{\"essentialConfiguration\":{\"connectorVersion\":\"\",\"executionType\":null,\"customFieldsRequestDetails\":null,\"instanceParameters\":{\"version\":\"1.0.0\",\"connectorKey\":\"uipath-uipath-dataservice\",\"activityType\":\"Curated\",\"objectName\":\"CreateEntityRecordCurated\",\"httpMethod\":\"POST\",\"operation\":null,\"eventOperation\":null,\"eventMode\":null,\"connectorObjects\":null,\"previewEndpoint\":null},\"objectName\":\"CreateEntityRecordCurated\",\"operation\":null,\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/v2/{entityName}/CreateEntityRecord\",\"unifiedTypesCompatible\":true,\"savedJitInputFieldId\":\"in_CreateEntityRecordCurated\"}}"
                                }
                              }
                            }
                          ],
                          "catch": {
                            "as": "citationInsertError",
                            "do": [
                              {
                                "Javascript_LogCitationError": {
                                  "run": {
                                    "script": {
                                      "code": "return { skipped: true, reason: 'duplicate_or_error' };",
                                      "language": "javascript",
                                      "arguments": "${{ \"$context\": $context, \"$workflow\": $workflow, \"$input\": $input }}"
                                    }
                                  },
                                  "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Javascript_LogCitationError\": $output } }" },
                                  "metadata": { "activityType": "JsInvoke", "displayName": "Log citation insert skip", "fullName": "JsInvoke" }
                                }
                              }
                            ]
                          },
                          "export": { "as": "{ ...$context, outputs: { ...$context?.outputs, \"Try_Catch_2\": $output } }" },
                          "metadata": { "activityType": "TryCatch", "displayName": "Insert CitationCheck (idempotent)", "fullName": "TryCatch" }
                        }
                      }
                    ],
                    "export": {
                      "as": "{ ...$context, outputs: { ...$context?.outputs, \"For_Each_2\": { ...$context?.outputs?.For_Each_2, results: [ ...($citationItemIndex == 0 ? [] : ($context?.outputs?.For_Each_2?.results ?? [])), ...([$output] ?? []) ] } } }"
                    }
                  }
                }
              ],
              "output": { "as": "${$context.outputs.For_Each_2}" },
              "metadata": { "activityType": "ForEach", "displayName": "Insert CitationCheck rows", "fullName": "ForEach" }
            }
          },
          {
            "Response_2": {
              "response": "${{ validated_citations: $context.variables.validated_citations, has_unverified: $context.variables.has_unverified, final_risk_tier: $context.outputs.Javascript_ValidateAndCheck.final_risk_tier, route: $context.outputs.Javascript_ValidateAndCheck.route }}",
              "markJobAsFailed": false,
              "then": "end",
              "metadata": { "activityType": "Response", "displayName": "Return gate result", "fullName": "Response" }
            }
          }
        ],
        "metadata": { "activityType": "Sequence", "displayName": "Sequence", "fullName": "Sequence" }
      }
    }
  ],
  "evaluate": { "mode": "strict", "language": "javascript" }
}
