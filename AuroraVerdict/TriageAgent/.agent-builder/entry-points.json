{
  "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
  "$id": "entry-points.json",
  "entryPoints": [
    {
      "filePath": "/content/agent.json",
      "uniqueId": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "type": "agent",
      "input": {
        "type": "object",
        "properties": {
          "alert_reference": {
            "type": "string",
            "description": "Unique alert identifier, e.g. ALERT-2026-0142"
          },
          "customer_name": {
            "type": "string",
            "description": "Display name of the customer or entity under review"
          },
          "evidence_bundle": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Array of evidence items, each with fields: evidence_id, category, summary, payload."
          }
        },
        "required": [
          "alert_reference",
          "customer_name",
          "evidence_bundle"
        ]
      },
      "output": {
        "type": "object",
        "properties": {
          "risk_tier": {
            "type": "string",
            "description": "Risk classification: low, medium, or high"
          },
          "confidence": {
            "type": "integer",
            "description": "Agent confidence in the risk_tier call, 0–100"
          },
          "recommendation": {
            "type": "string",
            "description": "Recommended action: escalate or close"
          },
          "rationale": {
            "type": "string",
            "description": "Explanation of the risk assessment"
          },
          "citations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of cited evidence_id strings"
          }
        }
      }
    }
  ]
}
