<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" exporter="UiPath Studio Web (https://uipath.com)" exporterVersion="b52d90e7">
  <bpmn:process id="Process_TriageOrchestration" name="TriageOrchestrationBpmn" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_AlertReference" name="alert_reference" type="string" elementId="Start_Triage" />
        <uipath:inputOutput id="Var_EvidenceResult" name="evidence_result" type="json" />
        <uipath:inputOutput id="Var_CustomerName" name="customer_name" type="string" />
        <uipath:inputOutput id="Var_EvidenceBundle" name="evidence_bundle" type="json" />
        <uipath:inputOutput id="Var_AlertId" name="alert_id" type="string" />
        <uipath:inputOutput id="Var_RiskTier" name="risk_tier" type="string" />
        <uipath:inputOutput id="Var_Confidence" name="confidence" type="integer" />
        <uipath:inputOutput id="Var_Recommendation" name="recommendation" type="string" />
        <uipath:inputOutput id="Var_Rationale" name="rationale" type="string" />
        <uipath:inputOutput id="Var_Citations" name="citations" type="json" />
        <uipath:inputOutput id="Var_ValidatedCitations" name="validated_citations" type="json" />
        <uipath:inputOutput id="Var_HasUnverified" name="has_unverified" type="boolean" />
        <uipath:inputOutput id="Var_RedFlags" name="red_flags" type="json" />
        <uipath:inputOutput id="Var_FinalRiskTier" name="final_risk_tier" type="string" />
        <uipath:inputOutput id="Var_TierWasForced" name="tier_was_forced" type="boolean" />
        <uipath:inputOutput id="Var_OriginalProposedTier" name="original_proposed_tier" type="string" />
        <uipath:inputOutput id="Var_GateRoute" name="route" type="string" />
        <uipath:inputOutput id="Var_AgentResult" name="agent_result" type="json" />
        <uipath:inputOutput id="Var_GateResult" name="gate_result" type="json" />
        <uipath:inputOutput id="Var_Route" name="route" type="string" default="medium_signoff" />
        <uipath:inputOutput id="Var_TierForcedDisplay" name="tier_forced_display" type="string" />
        <uipath:inputOutput id="Var_UnverifiedDisplay" name="unverified_display" type="string" />
        <uipath:inputOutput id="Var_CitationsDisplay" name="citations_display" type="string" />
        <uipath:inputOutput id="Var_HITLResult" name="hitl_result" type="json" />
        <uipath:inputOutput id="Var_SignOffResponse" name="sign_off" type="json" elementId="Start_Triage" />
        <uipath:inputOutput id="Var_AuditInput" name="audit_input" type="json" />
        <uipath:inputOutput id="Var_AuditResult" name="audit_result" type="json" />
        <uipath:inputOutput id="Var_ChallengerResult" name="challenger_result" type="json" />
        <uipath:inputOutput id="Var_ChallengerGateResult" name="challenger_gate_result" type="json" />
        <uipath:inputOutput id="Var_HighHITLResult" name="high_hitl_result" type="json" />
        <uipath:inputOutput id="Var_GuardResult" name="guard_result" type="json" />
        <uipath:inputOutput id="Var_HighAuditInput" name="high_audit_input" type="json" />
        <uipath:inputOutput id="Var_HighAuditResult" name="high_audit_result" type="json" />
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="Binding_EvidenceGather_Name" name="EvidenceGatherApi" type="process" elementId="Task_EvidenceGather" resource="process" resourceKey="AuroraVerdict.Api.EvidenceGatherApi" propertyAttribute="Name" />
        <uipath:binding id="Binding_EvidenceGather_Folder" name="EvidenceGatherApi" type="process" elementId="Task_EvidenceGather" resource="process" resourceKey="AuroraVerdict.Api.EvidenceGatherApi" propertyAttribute="FolderPath" />
        <uipath:binding id="Binding_TriageAgent_Name" name="TriageAgent" type="process" elementId="Task_TriageAgent" resource="process" resourceSubType="Agent" resourceKey="AuroraVerdict.Agent.TriageAgent" propertyAttribute="name" />
        <uipath:binding id="Binding_TriageAgent_Folder" name="TriageAgent" type="process" elementId="Task_TriageAgent" resource="process" resourceSubType="Agent" resourceKey="AuroraVerdict.Agent.TriageAgent" propertyAttribute="folderPath" />
        <uipath:binding id="Binding_DecisionGate_Name" name="DecisionGateApi" type="process" elementId="Task_DecisionGate" resource="process" resourceKey="AuroraVerdict.Api.DecisionGateApi" propertyAttribute="Name" />
        <uipath:binding id="Binding_DecisionGate_Folder" name="DecisionGateApi" type="process" elementId="Task_DecisionGate" resource="process" resourceKey="AuroraVerdict.Api.DecisionGateApi" propertyAttribute="FolderPath" />
        <uipath:binding id="Binding_AuditWrite_Name" name="AuditWriteApi" type="process" elementId="Task_AuditWrite" resource="process" resourceKey="AuroraVerdict.Api.AuditWriteApi" propertyAttribute="Name" />
        <uipath:binding id="Binding_AuditWrite_Folder" name="AuditWriteApi" type="process" elementId="Task_AuditWrite" resource="process" resourceKey="AuroraVerdict.Api.AuditWriteApi" propertyAttribute="FolderPath" />
        <uipath:binding id="Binding_ChallengerAgent_Name" name="ChallengerAgent" type="process" elementId="Task_ChallengerAgent" resource="process" resourceSubType="Agent" resourceKey="AuroraVerdict.Agent.ChallengerAgent" propertyAttribute="name" />
        <uipath:binding id="Binding_ChallengerAgent_Folder" name="ChallengerAgent" type="process" elementId="Task_ChallengerAgent" resource="process" resourceSubType="Agent" resourceKey="AuroraVerdict.Agent.ChallengerAgent" propertyAttribute="folderPath" />
      </uipath:bindings>
      <uipath:migrationVersion version="15" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_Triage" name="core.trigger.manual">
      <bpmn:extensionElements>
        <uipath:entryPointId value="c7f4a891-b3d2-4e5f-9a1c-2b3d4e5f6a7b" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_To_Evidence</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_EvidenceGather" name="Gather Evidence">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" type="string" value="cc9c1795-9602-4218-9402-9ed8e3d52f5b" />
            <uipath:input name="folderId" type="string" value="3152041" />
            <uipath:input name="folderKey" type="string" value="6f53970c-8d0e-4ad4-b334-218822a8c3b2" />
            <uipath:input name="folderPath" type="string" value="Shared/AuroraVerdictRun" />
            <uipath:input name="name" type="string" value="EvidenceGatherApi" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"alert_reference":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"alert_reference":"=vars.Var_AlertReference"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_EvidenceResult" />
          <uipath:output name="customer_name" type="string" source="=customer_name" var="Var_CustomerName" />
          <uipath:output name="evidence_bundle" type="json" source="=evidence_bundle" var="Var_EvidenceBundle" />
          <uipath:output name="alert_id" type="string" source="=alert_id" var="Var_AlertId" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_Evidence</bpmn:incoming>
      <bpmn:outgoing>Flow_Evidence_To_Agent</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TriageAgent" name="Run Triage Agent">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" type="string" value="23ca43ac-cf80-4e58-a274-21849810c4ea" />
            <uipath:input name="folderId" type="string" value="3152041" />
            <uipath:input name="folderKey" type="string" value="6f53970c-8d0e-4ad4-b334-218822a8c3b2" />
            <uipath:input name="folderPath" type="string" value="Shared/AuroraVerdictRun" />
            <uipath:input name="name" type="string" value="TriageAgent" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"alert_reference":{"type":"string"},"customer_name":{"type":"string"},"evidence_bundle":{"type":"array"}},"required":["alert_reference","customer_name","evidence_bundle"]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"alert_reference":"=vars.Var_AlertReference","customer_name":"=vars.Var_CustomerName","evidence_bundle":"=vars.Var_EvidenceBundle"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_AgentResult" />
          <uipath:output name="risk_tier" type="string" source="=risk_tier" var="Var_RiskTier" />
          <uipath:output name="confidence" type="integer" source="=confidence" var="Var_Confidence" />
          <uipath:output name="recommendation" type="string" source="=recommendation" var="Var_Recommendation" />
          <uipath:output name="rationale" type="string" source="=rationale" var="Var_Rationale" />
          <uipath:output name="citations" type="json" source="=citations" var="Var_Citations" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Evidence_To_Agent</bpmn:incoming>
      <bpmn:outgoing>Flow_Agent_To_Gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DecisionGate" name="Run Decision Gate">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" type="string" value="75a6e4fc-62e8-49c6-bacd-ab8df868f0d5" />
            <uipath:input name="folderId" type="string" value="3152041" />
            <uipath:input name="folderKey" type="string" value="6f53970c-8d0e-4ad4-b334-218822a8c3b2" />
            <uipath:input name="folderPath" type="string" value="Shared/AuroraVerdictRun" />
            <uipath:input name="name" type="string" value="DecisionGateApi" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"alert_id":{"type":"string"},"evidence_bundle":{"type":"string"},"agent_output":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"alert_id":"=vars.Var_AlertId","evidence_bundle":"=vars.Var_EvidenceBundle","agent_output":{"risk_tier":"=vars.Var_RiskTier","confidence":"=vars.Var_Confidence","recommendation":"=vars.Var_Recommendation","rationale":"=vars.Var_Rationale","citations":"=vars.Var_Citations"}}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_GateResult" />
          <uipath:output name="validated_citations" type="json" source="=validated_citations" var="Var_ValidatedCitations" />
          <uipath:output name="has_unverified" type="boolean" source="=has_unverified" var="Var_HasUnverified" />
          <uipath:output name="red_flags" type="json" source="=red_flags" var="Var_RedFlags" />
          <uipath:output name="final_risk_tier" type="string" source="=final_risk_tier" var="Var_FinalRiskTier" />
          <uipath:output name="tier_was_forced" type="boolean" source="=tier_was_forced" var="Var_TierWasForced" />
          <uipath:output name="original_proposed_tier" type="string" source="=original_proposed_tier" var="Var_OriginalProposedTier" />
          <uipath:output name="route" type="string" source="=route" var="Var_GateRoute" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Agent_To_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_Gate_To_ExtractRoute</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Task_ExtractRoute" name="Extract Route" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":{"gateRoute":"=vars.Var_GateRoute","gate":{"tierWasForced":"=vars.Var_TierWasForced","hasUnverified":"=vars.Var_HasUnverified","validatedCitations":"=vars.Var_ValidatedCitations"}}}]]></uipath:input>
          <uipath:output name="route" type="string" source="=result.route" var="Var_Route" />
          <uipath:output name="tier_forced_display" type="string" source="=result.tierForcedDisplay" var="Var_TierForcedDisplay" />
          <uipath:output name="unverified_display" type="string" source="=result.unverifiedDisplay" var="Var_UnverifiedDisplay" />
          <uipath:output name="citations_display" type="string" source="=result.citationsDisplay" var="Var_CitationsDisplay" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gate_To_ExtractRoute</bpmn:incoming>
      <bpmn:outgoing>Flow_ExtractRoute_To_Router</bpmn:outgoing>
      <bpmn:script><![CDATA[
var A = (typeof args !== 'undefined' && args) ? args : {};
if (A && A.gateRoute === undefined && A.args && typeof A.args === 'object') { A = A.args; }
var gateRoute = A.gateRoute;
var gate = A.gate;
var r = (typeof gateRoute === 'string' && gateRoute.length > 0) ? gateRoute : 'medium_signoff';
var g = (gate && typeof gate === 'object') ? gate : {};
var tierForced = (g.tierWasForced === true || g.tierWasForced === 'true');
var hasUnverif = (g.hasUnverified === true || g.hasUnverified === 'true');
var vc = g.validatedCitations;
var tierForcedDisplay = tierForced ? 'Yes - the decision gate enforced a higher minimum tier than the agent proposed' : 'No - the agent-proposed tier was accepted as-is';
var unverifiedDisplay = hasUnverif ? 'WARNING - one or more cited items could not be verified against the source evidence bundle' : 'All cited evidence was verified against the source bundle';
var citationsDisplay;
if (Array.isArray(vc) && vc.length > 0) {
  var parts = [];
  for (var i = 0; i < vc.length; i++) {
    var c = vc[i];
    if (typeof c === 'string') { parts.push(c); }
    else if (c === null || c === undefined) { continue; }
    else { parts.push(JSON.stringify(c)); }
  }
  citationsDisplay = parts.length > 0 ? parts.join('\n') : 'No citations were validated';
} else {
  citationsDisplay = 'No citations were validated';
}
return { route: r, tierForcedDisplay: tierForcedDisplay, unverifiedDisplay: unverifiedDisplay, citationsDisplay: citationsDisplay };
      ]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gateway_Route" name="Route?">
      <bpmn:incoming>Flow_ExtractRoute_To_Router</bpmn:incoming>
      <bpmn:outgoing>Flow_Router_To_HITL</bpmn:outgoing>
      <bpmn:outgoing>Flow_Router_To_LowBatch</bpmn:outgoing>
      <bpmn:outgoing>Flow_Router_To_HighChallenger</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="Task_HITL" name="Await human sign-off">
      <bpmn:incoming>Flow_Router_To_HITL</bpmn:incoming>
      <bpmn:outgoing>Flow_HITL_To_BuildAudit</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT30S</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:scriptTask id="Task_BuildAudit" name="Build Audit Payload" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":{"evidenceResult":{"alert_id":"=vars.Var_AlertId","customer_name":"=vars.Var_CustomerName","evidence_bundle":"=vars.Var_EvidenceBundle"},"agentResult":{"risk_tier":"=vars.Var_RiskTier","confidence":"=vars.Var_Confidence","recommendation":"=vars.Var_Recommendation","rationale":"=vars.Var_Rationale","citations":"=vars.Var_Citations"},"gateResult":{"validated_citations":"=vars.Var_ValidatedCitations","has_unverified":"=vars.Var_HasUnverified","red_flags":"=vars.Var_RedFlags","final_risk_tier":"=vars.Var_FinalRiskTier","tier_was_forced":"=vars.Var_TierWasForced","original_proposed_tier":"=vars.Var_OriginalProposedTier","route":"=vars.Var_GateRoute"},"signOff":"=vars.Var_SignOffResponse"}}]]></uipath:input>
          <uipath:output name="audit_input" type="json" source="=result" var="Var_AuditInput" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_HITL_To_BuildAudit</bpmn:incoming>
      <bpmn:outgoing>Flow_BuildAudit_To_AuditWrite</bpmn:outgoing>
      <bpmn:script><![CDATA[
var A = (typeof args !== 'undefined' && args) ? args : {};
if (A && A.evidenceResult === undefined && A.args && typeof A.args === 'object') { A = A.args; }
var er = (A.evidenceResult && typeof A.evidenceResult === 'object') ? A.evidenceResult : {};
var ar = (A.agentResult && typeof A.agentResult === 'object') ? A.agentResult : {};
var gr = (A.gateResult && typeof A.gateResult === 'object') ? A.gateResult : {};
var so = (A.signOff && typeof A.signOff === 'object') ? A.signOff : {};
var alertId = (er && er.alert_id) ? er.alert_id : '';
var finalRiskTier = (gr && gr.final_risk_tier) ? gr.final_risk_tier : 'medium';
var originalTier = (gr && gr.original_proposed_tier) ? gr.original_proposed_tier : ((ar && ar.risk_tier) ? ar.risk_tier : 'medium');
var routeTaken = (gr && gr.route) ? gr.route : 'medium_signoff';
var tierWasForced = (gr && gr.tier_was_forced) ? gr.tier_was_forced : false;
var redFlags = (gr && Array.isArray(gr.red_flags)) ? gr.red_flags : [];
var sc = (so && (so.SpecificContent || so.specificContent)) ? (so.SpecificContent || so.specificContent) : so;
var outcomeId = (sc && sc.outcome) ? sc.outcome : 'sign';
var humanAction = (outcomeId === 'sign') ? 'signed_agree' : 'override';
var overrideReason = (sc && sc.reason) ? sc.reason : '';
var finalDisposition = (humanAction === 'signed_agree') ? 'closed' : 'escalated';
var decisionMakerName = (sc && sc.reviewer) ? sc.reviewer : 'Analyst';
var now = '';
try { now = new Date().toISOString(); } catch (e) { now = ''; }
return {
  alert_id: alertId,
  final_risk_tier: finalRiskTier,
  original_proposed_tier: originalTier,
  route_taken: routeTaken,
  tier_was_forced: tierWasForced,
  red_flags: redFlags,
  decision_maker_name: decisionMakerName,
  human_action: humanAction,
  override_reason: overrideReason,
  decision_timestamp: now,
  final_disposition: finalDisposition,
  disposition_timestamp: now
};
      ]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Task_AuditWrite" name="Write Decision Record">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" type="string" value="4c01ff85-1bdd-4123-b715-9982a00eafd9" />
            <uipath:input name="folderId" type="string" value="3152041" />
            <uipath:input name="folderKey" type="string" value="6f53970c-8d0e-4ad4-b334-218822a8c3b2" />
            <uipath:input name="folderPath" type="string" value="Shared/AuroraVerdictRun" />
            <uipath:input name="name" type="string" value="AuditWriteApi" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"alert_id":{"type":"string"},"final_risk_tier":{"type":"string"},"original_proposed_tier":{"type":"string"},"route_taken":{"type":"string"},"tier_was_forced":{"type":"string"},"red_flags":{"type":"string"},"decision_maker_name":{"type":"string"},"human_action":{"type":"string"},"override_reason":{"type":"string"},"decision_timestamp":{"type":"string"},"final_disposition":{"type":"string"},"disposition_timestamp":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"alert_id":"=vars.Var_AuditInput.alert_id","final_risk_tier":"=vars.Var_AuditInput.final_risk_tier","original_proposed_tier":"=vars.Var_AuditInput.original_proposed_tier","route_taken":"=vars.Var_AuditInput.route_taken","tier_was_forced":"=vars.Var_AuditInput.tier_was_forced","red_flags":"=vars.Var_AuditInput.red_flags","decision_maker_name":"=vars.Var_AuditInput.decision_maker_name","human_action":"=vars.Var_AuditInput.human_action","override_reason":"=vars.Var_AuditInput.override_reason","decision_timestamp":"=vars.Var_AuditInput.decision_timestamp","final_disposition":"=vars.Var_AuditInput.final_disposition","disposition_timestamp":"=vars.Var_AuditInput.disposition_timestamp"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_AuditResult" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_BuildAudit_To_AuditWrite</bpmn:incoming>
      <bpmn:outgoing>Flow_AuditWrite_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Done" name="Triage complete">
      <bpmn:incoming>Flow_AuditWrite_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_LowBatch" name="Low-risk auto-batch (batch story)">
      <bpmn:incoming>Flow_Router_To_LowBatch</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_ChallengerAgent" name="Run Challenger Agent">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" type="string" value="3c3680a5-cf00-47fd-a9ca-ca5e78866b7b" />
            <uipath:input name="folderId" type="string" value="3152041" />
            <uipath:input name="folderKey" type="string" value="6f53970c-8d0e-4ad4-b334-218822a8c3b2" />
            <uipath:input name="folderPath" type="string" value="Shared/AuroraVerdictRun" />
            <uipath:input name="name" type="string" value="ChallengerAgent" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"alert_reference":{"type":"string"},"customer_name":{"type":"string"},"triage_output":{"type":"string"},"evidence_bundle":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"alert_reference":"=vars.Var_AlertReference","customer_name":"=vars.Var_CustomerName","triage_output":{"risk_tier":"=vars.Var_RiskTier","confidence":"=vars.Var_Confidence","recommendation":"=vars.Var_Recommendation","rationale":"=vars.Var_Rationale","citations":"=vars.Var_Citations"},"evidence_bundle":"=vars.Var_EvidenceBundle"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_ChallengerResult" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Router_To_HighChallenger</bpmn:incoming>
      <bpmn:outgoing>Flow_Challenger_To_ChallengerGate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ChallengerGate" name="Re-validate Challenger Citations">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" type="string" value="75a6e4fc-62e8-49c6-bacd-ab8df868f0d5" />
            <uipath:input name="folderId" type="string" value="3152041" />
            <uipath:input name="folderKey" type="string" value="6f53970c-8d0e-4ad4-b334-218822a8c3b2" />
            <uipath:input name="folderPath" type="string" value="Shared/AuroraVerdictRun" />
            <uipath:input name="name" type="string" value="DecisionGateApi" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"alert_id":{"type":"string"},"evidence_bundle":{"type":"string"},"agent_output":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"alert_id":"=vars.Var_AlertId","evidence_bundle":"=vars.Var_EvidenceBundle","agent_output":"=vars.Var_ChallengerResult"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_ChallengerGateResult" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Challenger_To_ChallengerGate</bpmn:incoming>
      <bpmn:outgoing>Flow_ChallengerGate_To_HighHITL</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_HighHITL" name="Senior/EDD Review">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Actions.HITL" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"title":{"type":"string"},"fields":{"type":"object"},"outcomes":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="HitlTaskArguments" type="json" target="bodyField"><![CDATA[{"title":"Senior/EDD Review — High-Risk Alert","fields":[{"id":"origRecommendation","label":"Original recommendation (call)","type":"text","direction":"input","value":"=vars.Var_Recommendation"},{"id":"origRiskTier","label":"Risk tier","type":"text","direction":"input","value":"=vars.Var_FinalRiskTier"},{"id":"origConfidence","label":"Agent confidence (%)","type":"number","direction":"input","value":"=vars.Var_Confidence"},{"id":"origCitedEvidence","label":"Cited evidence (recommendation)","type":"text","direction":"input","value":"=vars.Var_ValidatedCitations"},{"id":"challengerPosition","label":"Challenger position (agreed / disagreed)","type":"text","direction":"input","value":"=vars.Var_ChallengerResult.position"},{"id":"challengerDispute","label":"Disputed point + reasoning (if disagreed)","type":"text","direction":"input","value":"=vars.Var_ChallengerResult.disputed_point"},{"id":"challengerCitations","label":"Challenger validated citations","type":"text","direction":"input","value":"=vars.Var_ChallengerGateResult.validated_citations"},{"id":"unverifiedWarning","label":"Unverified challenger citations — do not rely on flagged items","type":"text","direction":"input","value":"=vars.Var_ChallengerGateResult.has_unverified"},{"id":"reviewerReason","label":"Reason (required if your call differs from the recommendation or the challenger)","type":"text","direction":"output"}],"outcomes":[{"id":"escalate","name":"Escalate","isPrimary":true,"action":"Continue"},{"id":"close","name":"Close","action":"Continue"},{"id":"send_to_edd","name":"Send to EDD","action":"Continue"}]}]]></uipath:input>
          <uipath:output name="Process response" type="Actions.HITL" var="Var_HighHITLResult" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ChallengerGate_To_HighHITL</bpmn:incoming>
      <bpmn:outgoing>Flow_HighHITL_To_Guard</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:scriptTask id="Task_OverrideReasonGuard" name="Validate Reviewer Reason" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":{"agentResult":{"risk_tier":"=vars.Var_RiskTier","confidence":"=vars.Var_Confidence","recommendation":"=vars.Var_Recommendation","rationale":"=vars.Var_Rationale","citations":"=vars.Var_Citations"},"challengerResult":"=vars.Var_ChallengerResult","highHitlResult":"=vars.Var_HighHITLResult"}}]]></uipath:input>
          <uipath:output name="guard_result" type="json" source="=result" var="Var_GuardResult" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_HighHITL_To_Guard</bpmn:incoming>
      <bpmn:outgoing>Flow_Guard_To_BuildHighAudit</bpmn:outgoing>
      <bpmn:script><![CDATA[
var finalCall = (highHitlResult && highHitlResult.outcomeId) ? highHitlResult.outcomeId : '';
var origRecommendation = (agentResult && agentResult.recommendation) ? agentResult.recommendation.toLowerCase() : '';
var challengerPosition = (challengerResult && challengerResult.position) ? challengerResult.position.toLowerCase() : 'agreed';
var reviewerReason = (highHitlResult && highHitlResult.fields && highHitlResult.fields.reviewerReason) ? highHitlResult.fields.reviewerReason : '';
var differsFromRec = (finalCall !== origRecommendation);
var differsFromChallenger = (challengerPosition === 'agreed') ? differsFromRec : !differsFromRec;
var requiresReason = differsFromRec || differsFromChallenger;
if (requiresReason && (!reviewerReason || reviewerReason.trim() === '')) {
  throw new Error('OVERRIDE_REASON_REQUIRED: A reason is required because your final call differs from the recommendation or the challenger.');
}
return { requires_reason: requiresReason, reviewer_reason: reviewerReason };
      ]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Task_BuildHighAudit" name="Build High-Risk Audit Payload" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"args":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"args":{"evidenceResult":{"alert_id":"=vars.Var_AlertId","customer_name":"=vars.Var_CustomerName","evidence_bundle":"=vars.Var_EvidenceBundle"},"agentResult":{"risk_tier":"=vars.Var_RiskTier","confidence":"=vars.Var_Confidence","recommendation":"=vars.Var_Recommendation","rationale":"=vars.Var_Rationale","citations":"=vars.Var_Citations"},"gateResult":{"validated_citations":"=vars.Var_ValidatedCitations","has_unverified":"=vars.Var_HasUnverified","red_flags":"=vars.Var_RedFlags","final_risk_tier":"=vars.Var_FinalRiskTier","tier_was_forced":"=vars.Var_TierWasForced","original_proposed_tier":"=vars.Var_OriginalProposedTier","route":"=vars.Var_GateRoute"},"challengerResult":"=vars.Var_ChallengerResult","highHitlResult":"=vars.Var_HighHITLResult"}}]]></uipath:input>
          <uipath:output name="high_audit_input" type="json" source="=result" var="Var_HighAuditInput" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Guard_To_BuildHighAudit</bpmn:incoming>
      <bpmn:outgoing>Flow_BuildHighAudit_To_HighAuditWrite</bpmn:outgoing>
      <bpmn:script><![CDATA[
var alertId = (evidenceResult && evidenceResult.alert_id) ? evidenceResult.alert_id : '';
var finalRiskTier = (gateResult && gateResult.final_risk_tier) ? gateResult.final_risk_tier : 'high';
var originalTier = (gateResult && gateResult.original_proposed_tier) ? gateResult.original_proposed_tier : ((agentResult && agentResult.risk_tier) ? agentResult.risk_tier : 'high');
var tierWasForced = (gateResult && gateResult.tier_was_forced) ? gateResult.tier_was_forced : false;
var redFlags = (gateResult && Array.isArray(gateResult.red_flags)) ? gateResult.red_flags : [];
var finalCall = (highHitlResult && highHitlResult.outcomeId) ? highHitlResult.outcomeId : 'escalate';
var origRecommendation = (agentResult && agentResult.recommendation) ? agentResult.recommendation : '';
var differsFromRec = (finalCall !== origRecommendation);
var humanAction = differsFromRec ? 'override' : 'signed_agree';
var reviewerReason = (highHitlResult && highHitlResult.fields && highHitlResult.fields.reviewerReason) ? highHitlResult.fields.reviewerReason : '';
var decisionMakerName = (highHitlResult && highHitlResult.completedBy) ? highHitlResult.completedBy : 'Senior Reviewer';
var challengerOutcome = (challengerResult && challengerResult.position) ? challengerResult.position : 'agreed';
var challengerDispute = '';
if (challengerResult && challengerResult.position === 'disagreed') {
  var dp = challengerResult.disputed_point || '';
  var rs = challengerResult.reasoning || '';
  challengerDispute = dp + (rs ? '\n' + rs : '');
}
var DISPOSITION_MAP = { 'escalate': 'escalated', 'close': 'closed', 'send_to_edd': 'sent_to_edd' };
var finalDisposition = DISPOSITION_MAP[finalCall] || 'escalated';
var now = new Date().toISOString();
return {
  alert_id: alertId,
  final_risk_tier: finalRiskTier,
  original_proposed_tier: originalTier,
  route_taken: 'high_challenger',
  tier_was_forced: tierWasForced,
  red_flags: redFlags,
  challenger_outcome: challengerOutcome,
  challenger_dispute: challengerDispute,
  reviewer_reason: reviewerReason,
  decision_maker_name: decisionMakerName,
  human_action: humanAction,
  override_reason: reviewerReason,
  decision_timestamp: now,
  final_disposition: finalDisposition,
  disposition_timestamp: now
};
      ]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Task_HighAuditWrite" name="Write High-Risk Decision Record">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.ExecuteApiWorkflowAsync" version="v1" />
          <uipath:context>
            <uipath:input name="releaseKey" type="string" value="4c01ff85-1bdd-4123-b715-9982a00eafd9" />
            <uipath:input name="folderId" type="string" value="3152041" />
            <uipath:input name="folderKey" type="string" value="6f53970c-8d0e-4ad4-b334-218822a8c3b2" />
            <uipath:input name="folderPath" type="string" value="Shared/AuroraVerdictRun" />
            <uipath:input name="name" type="string" value="AuditWriteApi" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"alert_id":{"type":"string"},"final_risk_tier":{"type":"string"},"original_proposed_tier":{"type":"string"},"route_taken":{"type":"string"},"tier_was_forced":{"type":"string"},"red_flags":{"type":"string"},"challenger_outcome":{"type":"string"},"challenger_dispute":{"type":"string"},"reviewer_reason":{"type":"string"},"decision_maker_name":{"type":"string"},"human_action":{"type":"string"},"override_reason":{"type":"string"},"decision_timestamp":{"type":"string"},"final_disposition":{"type":"string"},"disposition_timestamp":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"alert_id":"=vars.Var_HighAuditInput.alert_id","final_risk_tier":"=vars.Var_HighAuditInput.final_risk_tier","original_proposed_tier":"=vars.Var_HighAuditInput.original_proposed_tier","route_taken":"=vars.Var_HighAuditInput.route_taken","tier_was_forced":"=vars.Var_HighAuditInput.tier_was_forced","red_flags":"=vars.Var_HighAuditInput.red_flags","challenger_outcome":"=vars.Var_HighAuditInput.challenger_outcome","challenger_dispute":"=vars.Var_HighAuditInput.challenger_dispute","reviewer_reason":"=vars.Var_HighAuditInput.reviewer_reason","decision_maker_name":"=vars.Var_HighAuditInput.decision_maker_name","human_action":"=vars.Var_HighAuditInput.human_action","override_reason":"=vars.Var_HighAuditInput.override_reason","decision_timestamp":"=vars.Var_HighAuditInput.decision_timestamp","final_disposition":"=vars.Var_HighAuditInput.final_disposition","disposition_timestamp":"=vars.Var_HighAuditInput.disposition_timestamp"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_HighAuditResult" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_BuildHighAudit_To_HighAuditWrite</bpmn:incoming>
      <bpmn:outgoing>Flow_HighAuditWrite_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_HighDone" name="High-risk triage complete">
      <bpmn:incoming>Flow_HighAuditWrite_To_End</bpmn:incoming>
    </bpmn:endEvent>
